<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.EmpExprMapper">

    <!-- 批量插入工作经历 -->
    <insert id="insertBatch">
        insert into emp_expr(emp_id, company, job, begin, end) values
        <foreach collection="list" item="item" separator=",">
            (#{item.empId}, #{item.company}, #{item.job}, #{item.begin}, #{item.end})
        </foreach>
    </insert>

    <!-- 根据员工ID列表批量查询工作经历（用于回显） -->
    <select id="selectByEmpIds" resultType="com.itheima.pojo.EmpExpr">
        select id, emp_id, company, job, begin, end
        from emp_expr
        where emp_id in
        <foreach collection="empIds" item="empId" open="(" separator="," close=")">
            #{empId}
        </foreach>
        order by begin desc
    </select>

    <!-- 根据员工ID批量删除工作经历 -->
    <delete id="deleteByEmpIds">
        delete from emp_expr where emp_id in
        <foreach collection="empIds" item="empId" open="(" separator="," close=")">
            #{empId}
        </foreach>
    </delete>

</mapper>